{
  "name": "@actionbookdev/cli",
  "version": "1.0.0-alpha.9",
  "private": false,
  "description": "Actionbook CLI - Browser automation for AI agents",
  "bin": {
    "actionbook": "./bin/actionbook.js"
  },
  "files": [
    "bin",
    "scripts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "build": "cargo build --release",
    "test": "cargo test",
    "test:ut": "cargo test --lib",
    "test:e2e": "RUN_E2E_TESTS=true cargo test --test e2e -- --test-threads=8",
    "lint": "pnpm lint:fmt && pnpm lint:clippy",
    "lint:fmt": "cargo fmt -- --check",
    "lint:clippy": "cargo clippy -- -D warnings",
    "fmt": "cargo fmt",
    "clean": "cargo clean",
    "dev": "cargo watch -w src -w Cargo.toml -x build",
    "dev:check": "cargo watch -w src -w Cargo.toml -x check",
    "dev:test": "cargo watch -w src -w tests -w Cargo.toml -x test"
  },
  "optionalDependencies": {
    "@actionbookdev/cli-darwin-arm64": "workspace:*",
    "@actionbookdev/cli-darwin-x64": "workspace:*",
    "@actionbookdev/cli-linux-x64-gnu": "workspace:*",
    "@actionbookdev/cli-linux-arm64-gnu": "workspace:*",
    "@actionbookdev/cli-win32-x64": "workspace:*",
    "@actionbookdev/cli-win32-arm64": "workspace:*"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "actionbook",
    "cli",
    "ai-agent",
    "browser-automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/actionbook/actionbook.git",
    "directory": "packages/cli"
  },
  "homepage": "https://actionbook.dev",
  "author": "Actionbook Team",
  "license": "MIT"
}
